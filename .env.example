# Bothost sets BOT_TOKEN automatically for Telegram bots.
# Locally you can use either BOT_TOKEN or GAME_BOT_TOKEN.
BOT_TOKEN=1234567890:replace_with_token
GAME_BOT_TOKEN=
OWNER_ID=123456789
ADMIN_IDS=
MAIN_CHAT_ID=
DEVELOPER_ID=
DEVELOPER_USERNAME=@username
# Bothost Dockerfile sets DATABASE_URL=file:/app/data/flood_games.sqlite by default.
DATABASE_URL=file:./data/flood_games.sqlite
TELEGRAM_API_ROOT=https://api.telegram.org
TELEGRAM_PROXY_URL=
LAUNCH_RETRY_SECONDS=15
LOG_LEVEL=info
